    "def run_sim(M, c, W):\n",
    "    Q0 = f * c * M\n",
    "    y0 = [Q0, 0, 0, 0, 0, 0]\n",
    "    sol = solve_ivp(model, (0, 48), y0, args=(k_abs, k_e, W, p, K_D, n, mu), t_eval=np.arange(0, 48, 2))\n",
    "    return sol\n",
    "\n",
    "results = []\n",
    "\n",
    "for w in W:\n",
    "    for c in c_type:\n",
    "        for M in M_choc:\n",
    "\n",
    "            sol = run_sim(M, c, w)\n",
    "\n",
    "            results.append({\n",
    "                \"W\": w,\n",
    "                \"c\": c,\n",
    "                \"M\": M,\n",
    "                \"sol\": sol,\n",
    "                \"Smax\": np.max(sol.y[2:6]),\n",
    "                \"Dmax\": np.max(sol.y[1])\n",
    "            })\n"
   ]
